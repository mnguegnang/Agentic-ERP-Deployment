# .env.example
# Copy to .env and fill in all values before running scripts/provision.sh
# DO NOT commit .env to version control.

# ─── Azure Authentication ──────────────────────────────────────────────────
# Service principal credentials JSON from:
#   az ad sp create-for-rbac --role Contributor --scopes /subscriptions/<SUB_ID> --json-auth
AZURE_CREDENTIALS={"clientId":"","clientSecret":"","subscriptionId":"","tenantId":""}

# Azure resource group name (must exist before running provision.sh)
RG_NAME=rg-agentic-erp-prod

# Azure Container Registry name (must match Project 1 secret ACR_NAME)
ACR_NAME=your-acr-name

# AKS cluster name (output after first provision; set here for subsequent deploys)
AKS_NAME=erpcopilot-aks-production

# ─── Database Credentials ──────────────────────────────────────────────────
PG_PASSWORD=CHANGE_ME_strong_password_32chars

# ─── Cache ────────────────────────────────────────────────────────────────
# Redis access key (from Azure Portal → Redis → Access Keys)
REDIS_KEY=CHANGE_ME

# ─── Smoke Tests ─────────────────────────────────────────────────────────
# Base URL for smoke-test.sh (e.g. https://your-domain.com)
SMOKE_BASE_URL=https://REPLACE_WITH_YOUR_DOMAIN

# ─── Monitoring ──────────────────────────────────────────────────────────
# Application Insights connection string (output after first provision)
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ─── Alerts ───────────────────────────────────────────────────────────────
ALERT_EMAIL=oncall@your-org.com

# ─── GitHub Secrets (reference — not used by scripts directly) ───────────
# These must be set in the Agentic-ERP-Deploy GitHub repo settings:
#   AZURE_CREDENTIALS   — same as above
#   RG_NAME             — same as above
#   ACR_NAME            — same as above
#   AKS_NAME            — same as above
#   SMOKE_BASE_URL      — same as above
